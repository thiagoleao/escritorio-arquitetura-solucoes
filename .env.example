# "openai" ou "anthropic"
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

PLANNER_API_URL=
PLANNER_API_KEY=

AUTH_SECRET=
AUTH_TRUST_HOST=true
# Obrigatório em produção atrás do Cloud Run: sem isso, o callbackUrl do login
# é resolvido para o endereço interno do container (ex: http://0.0.0.0:8080).
AUTH_URL=
